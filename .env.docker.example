# Docker Compose environment file for local infra (Postgres, Redis).
# Copy to .env.docker and replace BOTH passwords with strong randoms:
#   openssl rand -base64 24
#
# This file is loaded via `docker compose --env-file .env.docker ...`
# (or via the Makefile, which bakes the flag in).
#
# NOTE: This is intentionally separate from backend/.env, which holds
# application secrets (DEEPSEEK_API_KEY, etc.).

# Postgres
POSTGRES_DB=studyverify
POSTGRES_USER=studyverify
POSTGRES_PASSWORD=change_me_locally
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=change_me_locally
REDIS_PORT=6379
