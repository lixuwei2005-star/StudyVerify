# Docker Compose environment file for local infra (Postgres, Redis, api).
# Copy to .env.docker and replace BOTH passwords with strong randoms:
#   openssl rand -hex 24
# (NOT base64 — base64 includes / which breaks URL passwords when
# POSTGRES_PASSWORD is interpolated into DATABASE_URL.)
#
# This file is loaded via `docker compose --env-file .env.docker ...`
# (or via the Makefile, which bakes the flag in).
#
# NOTE: This is intentionally separate from backend/.env, which holds
# application secrets used by local-uvicorn workflows. The api container
# reads its config from this file via docker-compose's environment:.

# Postgres
POSTGRES_DB=studyverify
POSTGRES_USER=studyverify
POSTGRES_PASSWORD=change_me_locally
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=change_me_locally
REDIS_PORT=6379

# ─── Application (api container) ───
# These mirror values from backend/.env but are explicitly listed
# here because docker-compose passes them into the api container.
# Do NOT commit real values. Copy to .env.docker locally and fill in.

# Required for live /api/v1/solve only; base health checks work empty.
DEEPSEEK_API_KEY=

# Optional: enables RAG retrieval (Step 6.2+) and embedding generation.
# Without this key, embedding_status falls back to 'failed' on new verifier
# rows and RAG queries return empty results.
OPENAI_API_KEY=

# Optional, with sensible defaults; uncomment to override
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_REASONING_EFFORT=none
# LOG_LEVEL=INFO
# ENV=development
# SANDBOX_TIMEOUT_SECONDS=5
# SANDBOX_MEMORY_MB=128

# Host port the api binds to (container always 8000)
# API_PORT=8000

# CORS — frontend origins allowed to call the API.
# Exact origins as CSV; regex catches Vercel preview deploys (one subdomain per PR).
# Starlette's CORSMiddleware does not treat https://*.vercel.app as a wildcard
# inside allow_origins, so preview URLs must go through CORS_ALLOW_ORIGIN_REGEX.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://studyverify.vercel.app
CORS_ALLOW_ORIGIN_REGEX=https://[a-zA-Z0-9-]+\.vercel\.app
