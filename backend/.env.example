# Copy to .env and edit as needed. All settings have defaults.
APP_NAME=studyverify-backend
APP_VERSION=0.1.0
LOG_LEVEL=INFO
ENV=development

# DeepSeek LLM (OpenAI-compatible). Required for /api/v1/solve and integration tests.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
# reasoning_effort: "none" | "low" | "medium" | "high". Solver defaults to "none".
DEEPSEEK_REASONING_EFFORT=none
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3  # DEPRECATED in 6.1 — gateway owns retry; kept for .env compatibility

# Solver self-verification sandbox (subprocess-based; POSIX-only rlimits).
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEMORY_MB=128
# Leave empty to use the interpreter running the backend (sys.executable).
SANDBOX_PYTHON_PATH=

# Postgres. REQUIRED — empty triggers loud-fail.
# NOTE: .env does NOT do variable substitution. Copy literal values from
# .env.docker (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_PORT / POSTGRES_DB).
# Example shape:
#   DATABASE_URL=postgresql+asyncpg://studyverify:<password>@localhost:5432/studyverify
DATABASE_URL=
# Optional override for tests (default = in-memory SQLite via aiosqlite).
DATABASE_URL_TEST=sqlite+aiosqlite:///:memory:
DB_ECHO_SQL=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30

# Optional OpenAI fallback provider. Disabled by default.
# To enable fallback, set both LLM_FALLBACK_ENABLED=true and OPENAI_API_KEY.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_PROVIDER=openai
